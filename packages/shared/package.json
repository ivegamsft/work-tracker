{
  "name": "@e-clat/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, errors, and constants for E-CLAT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('tsconfig.tsbuildinfo', { force: true });\" && node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0"
  }
}
